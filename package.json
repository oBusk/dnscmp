{
  "name": "@dnscmp/repo",
  "private": true,
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "25.9.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "build": "pnpm --filter @dnscmp/core build && pnpm --filter @dnscmp/providers build && pnpm --filter dnscmp build",
    "start": "node packages/cli/src/index.ts",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.9.3"
  }
}
